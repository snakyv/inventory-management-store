@model Inventory

<div class="card border-primary m-1 p-1">
    <div class="bg-light p-2">
        <h4>
            @Model.Name

            <span class="badge rounded-pill bg-primary text-white"
                  style="float:right">
                <small>@((Model.Price ?? 0).ToString("c"))</small>
            </span>
        </h4>
    </div>

    <form id="@Model.InventoryID" asp-page="/Cart" method="post">
        <input type="hidden" name="inventoryId" value="@Model.InventoryID" />

        <input type="hidden"
               name="returnUrl"
               value="@ViewContext.HttpContext.Request.PathAndQuery()" />

        <div class="card-text p-2">
            <p class="mb-1">
                <strong>Quantity:</strong>
                @(Model.Quantity ?? 0)
            </p>

            <p class="mb-1">
                <strong>Part:</strong>
                @(Model.Part?.Name ?? "No part")
            </p>

            <p class="mb-1">
                <strong>Invoice:</strong>
                @(Model.Invoice?.SerialNumber ?? "No invoice")
            </p>

            <button type="submit"
                    class="btn btn-success btn-sm"
                    style="float:right">
                Add To Cart
            </button>
        </div>
    </form>
</div>