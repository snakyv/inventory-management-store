@page "/admin/products/edit/{id:int}"
@page "/admin/products/create"
@inherits OwningComponentBase<IStoreRepository>

<style>
    div.validation-message {
        color: rgb(220, 53, 69);
        font-weight: 500;
    }
</style>

<h3 class="bg-@ThemeColor text-white text-center p-2">
    @TitleText Inventory Item
</h3>

<EditForm Model="InventoryItem"
          OnValidSubmit="SaveInventoryItem">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (InventoryItem.InventoryID != 0)
    {
        <div class="form-group mb-2">
            <label>ID</label>
            <input class="form-control"
                   disabled
                   value="@InventoryItem.InventoryID" />
        </div>
    }

    <div class="form-group mb-2">
        <label>Name</label>
        <ValidationMessage For="@(() => InventoryItem.Name)" />
        <InputText class="form-control"
                   @bind-Value="InventoryItem.Name" />
    </div>

    <div class="form-group mb-2">
        <label>Price</label>
        <ValidationMessage For="@(() => InventoryItem.Price)" />
        <InputNumber class="form-control"
                     @bind-Value="InventoryItem.Price" />
    </div>

    <div class="form-group mb-2">
        <label>Quantity</label>
        <ValidationMessage For="@(() => InventoryItem.Quantity)" />
        <InputNumber class="form-control"
                     @bind-Value="InventoryItem.Quantity" />
    </div>

    <div class="form-group mb-2">
        <label>Part category</label>
        <ValidationMessage For="@(() => InventoryItem.PartID)" />

        <InputSelect TValue="int?"
                     class="form-control"
                     @bind-Value="InventoryItem.PartID">
            <option value="">Choose part category</option>

            @foreach (Part part in Parts)
            {
                <option value="@part.PartID">
                    @part.Name
                </option>
            }
        </InputSelect>
    </div>

    <div class="form-group mb-2">
        <label>Invoice</label>

        <InputSelect TValue="int?"
                     class="form-control"
                     @bind-Value="InventoryItem.InvoiceID">
            <option value="">No invoice</option>

            @foreach (Invoice invoice in Invoices)
            {
                <option value="@invoice.InvoiceID">
                    @invoice.SerialNumber
                </option>
            }
        </InputSelect>
    </div>

    <div class="mt-3">
        <button type="submit"
                class="btn btn-@ThemeColor">
            Save
        </button>

        <a class="btn btn-secondary"
           href="/admin/products">
            Cancel
        </a>
    </div>
</EditForm>

@code {
    public IStoreRepository Repository => Service;

    [Inject]
    public NavigationManager? NavManager { get; set; }

    [Parameter]
    public int Id { get; set; }

    public Inventory InventoryItem { get; set; } = new();

    public IEnumerable<Part> Parts { get; set; }
        = Enumerable.Empty<Part>();

    public IEnumerable<Invoice> Invoices { get; set; }
        = Enumerable.Empty<Invoice>();

    protected async override Task OnParametersSetAsync()
    {
        Parts = await Repository.Parts
            .OrderBy(p => p.Name)
            .ToListAsync();

        Invoices = await Repository.Invoices
            .OrderBy(i => i.InvoiceID)
            .ToListAsync();

        if (Id != 0)
        {
            InventoryItem = await Repository.InventoryItems
                .FirstOrDefaultAsync(i => i.InventoryID == Id)
                ?? new Inventory();
        }
        else
        {
            InventoryItem = new Inventory();
        }
    }

    public void SaveInventoryItem()
    {
        InventoryItem.Part = null;
        InventoryItem.Invoice = null;

        if (Id == 0)
        {
            Repository.CreateInventory(InventoryItem);
        }
        else
        {
            Repository.SaveInventory(InventoryItem);
        }

        NavManager?.NavigateTo("/admin/products", forceLoad: true);
    }

    public string ThemeColor =>
        Id == 0 ? "primary" : "warning";

    public string TitleText =>
        Id == 0 ? "Create" : "Edit";
}